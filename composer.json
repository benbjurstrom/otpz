{
    "name": "benbjurstrom/otpz",
    "description": "First Factor One-Time Passwords for Laravel (Passwordless OTP Login)",
    "keywords": [
        "Ben Bjurstrom",
        "laravel",
        "otpz"
    ],
    "homepage": "https://github.com/benbjurstrom/otpz",
    "license": "MIT",
    "authors": [
        {
            "name": "Ben Bjurstrom",
            "email": "benbjurstrom@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "nunomaduro/collision": "^7.10.0||^8.5.0",
        "larastan/larastan": "^2.9.13||^3.0",
        "orchestra/testbench": "^8.22.0||^9.10.0||^10.0||^11.0",
        "pestphp/pest": "^2.36||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.7||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.4||^3.0||^4.0",
        "phpstan/phpstan": "^1.12.12||^2.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^1.2.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.4.1||^2.0"
    },
    "autoload": {
        "psr-4": {
            "BenBjurstrom\\Otpz\\": "src/",
            "BenBjurstrom\\Otpz\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BenBjurstrom\\Otpz\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-otpz --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BenBjurstrom\\Otpz\\OtpzServiceProvider"
            ],
            "aliases": {
                "Otpz": "BenBjurstrom\\Otpz\\Facades\\Otpz"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
